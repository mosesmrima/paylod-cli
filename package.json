{
  "name": "@paylod/cli",
  "version": "0.2.0",
  "description": "The paylod CLI — accept M-Pesa (Safaricom Daraja) payments from your terminal. STK push, live status, webhook forwarding, and offline Daraja error decoding.",
  "homepage": "https://paylod.dev/docs/cli",
  "bugs": {
    "url": "https://github.com/mosesmrima/paylod-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosesmrima/paylod-cli.git"
  },
  "author": "paylod / Moses Mrima",
  "type": "module",
  "bin": {
    "paylod": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "test": "npm run build:test && node --test \"build/test/lib/*.test.js\" \"build/test/commands/*.test.js\"",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "catalog:sync": "node scripts/vendor-daraja-catalog.mjs",
    "catalog:check": "node scripts/vendor-daraja-catalog.mjs --check",
    "prepublishOnly": "npm run catalog:check && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "mpesa",
    "m-pesa",
    "daraja",
    "safaricom",
    "payments",
    "kenya",
    "stk-push",
    "paylod",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

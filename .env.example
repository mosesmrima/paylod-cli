# paylod CLI — environment variables.
#
# Copy to `.env` and fill in. NOTHING here is required: `paylod login` stores your
# credentials in the OS keychain (or a 0600 config file) and every command works
# without a .env at all. These exist for CI and for pointing at a non-prod stack.
#
# ⚠️  NEVER commit a real key. `.env` is gitignored.

# Merchant API key for the data plane (collect / status).
# Setting this skips the config file entirely — this is how you run paylod in CI.
# mp_test_… is the sandbox; mp_live_… moves REAL MONEY.
PAYLOD_API_KEY=mp_test_replace_me

# Webhook signing secret, so `paylod listen` can verify HMAC signatures.
# Get one with: paylod webhooks secret
PAYLOD_WEBHOOK_SECRET=whsec_replace_me

# --- Optional overrides ------------------------------------------------------

# API base. Default: https://paylod.dev/functions/v1
# NOTE: api.paylod.dev/v1 is advertised publicly but does NOT route today.
# PAYLOD_API_BASE=https://paylod.dev/functions/v1

# Where the CLI stores config. Default: ~/.config/paylod
# PAYLOD_CONFIG_DIR=/custom/path

# Never use the OS keychain; use the 0600 config file instead.
# Useful on headless Linux / containers with no unlocked secret service.
# PAYLOD_NO_KEYCHAIN=1

# Print stack traces on error.
# PAYLOD_DEBUG=1

# Disable colour (https://no-color.org).
# NO_COLOR=1
